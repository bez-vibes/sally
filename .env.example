# Copy to .env and fill in. Everything optional — Sally runs fully without any keys
# (drafting falls back to deterministic templates; enrichment is skipped).

# --- LLM drafting (pick ONE provider; default is gemini) ---
SALLY_LLM_PROVIDER=gemini          # gemini | groq | anthropic | template
GEMINI_API_KEY=                    # free key: https://aistudio.google.com/apikey
GROQ_API_KEY=                      # free key: https://console.groq.com/keys
ANTHROPIC_API_KEY=                 # bring-your-own for production

# --- Enrichment (optional, just-in-time, top-N only) ---
BRAVE_API_KEY=                     # shop enrichment: https://brave.com/search/api/
APIFY_TOKEN=                       # reseller enrichment: https://apify.com/

# --- Slack morning digest (optional) ---
SLACK_WEBHOOK_URL=                 # incoming webhook for the daily digest
